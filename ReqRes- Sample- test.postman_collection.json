    {
      "name": "Create new Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status of code 201\", ()=>{\r",
              "    pm.response.to.have.status(201);\r",
              "})\r",
              "\r",
              "pm.test(\"Response time should be less than 500ms\",()=>{\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "})\r",
              "\r",
              "let res = pm.response.json();\r",
              "\r",
              "pm.test(\"Response has Data\",()=>{\r",
              "    pm.expect(res.data).to.not.be.null;\r",
              "})\r",
              "\r",
              "pm.test(\"Name is correct\",()=>{\r",
              "    pm.expect(res.data.data.name).to.eq(\"Wireless Headphones\");\r",
              "})\r",
              "pm.test(\"content-type should br application.json\",()=>{\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.eql(\"application/json; charset=utf-8\");\r",
              "\r",
              "})\r",
              "//let res = pm.response.json();\r",
              "// Debug\r",
              "console.log(\"POST ID:\", res.data.id);\r",
              "\r",
              "// Store ID for chaining\r",
              "pm.environment.set(\"product_id\", res.data.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
